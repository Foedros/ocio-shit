# Ocio Shit — plantilla de entorno. Copia a .env (gitignored) y rellena.
# El FRONTEND solo usará SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY (vía VITE_*, ver app).
# Lo demás (SECRET, DB_URL, credenciales) es SOLO para los scripts locales de carga/verificación
# y NUNCA entra en el bundle, el repo ni los logs (tecnico.md §3.2.sec).

# ── Supabase (Sprint A) ──────────────────────────────────────────────────────
# Las PUBLIC_* son las que usará TAMBIÉN el frontend (convención SvelteKit: PUBLIC_ = cliente).
# Project Settings → Data API (URL) / API Keys (publishable + secret).
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx          # SIN PUBLIC_ → nunca va al cliente

# Project Settings → Database → Connection string → URI (incluye la contraseña de la BD).
# Necesaria para aplicar DDL (schema/rls) y ejecutar el SQL del compilador (PostgREST no hace DDL).
# Solo local (este .env gitignored); jamás en el frontend.
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# El ÚNICO usuario del archivo (Supabase Auth) = tu login en la app. Los scripts crean/usan esta
# cuenta; su uid pasa a ser el owner_id de todas las filas (RLS). Contraseña fuerte.
OCIO_AUTH_EMAIL=tu-email@ejemplo.com
OCIO_AUTH_PASSWORD=una-contraseña-larga-y-única

# ── Despliegue de Edge Functions (Fase 3 carátulas) ──────────────────────────
# Access token PERSONAL de Supabase (Management API) para `npx supabase functions deploy` y
# `secrets set`. Se crea en https://supabase.com/dashboard/account/tokens. SOLO local, como todo
# lo de este bloque. NO es la secret del proyecto: es tu token de cuenta (rotable/revocable).
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx

# ── Enriquecimiento (HISTÓRICO · ya aplicado y guardado en Supabase) ──────────
# El enriquecimiento por API (TMDB cine/series, Steam videojuegos) fue una tarea de UNA VEZ, ya
# ejecutada; sus datos viven en Supabase y los metadatos nuevos se introducen A MANO desde la app.
# NI el frontend NI los scripts activos (carga / verificación / tests) leen estas claves.
# Solo las necesitan los scripts de enriquecimiento HISTÓRICOS (app/scripts/tmdb-*.mjs) si se
# REEJECUTAN. Las claves originales fueron REVOCADAS (2026-06-26) → para reusar esos scripts hay que
# GENERAR CLAVES NUEVAS en el panel de TMDB. Déjalas vacías si no reenriqueces.
# NOTA (Fase 3 carátulas): TMDB_API_KEY también se sube como SECRET de la Edge Function
# `buscar_caratula` (npx supabase secrets set) — vive en el servidor de Supabase, nunca en el bundle.
TMDB_API_KEY=
# Steam: NINGÚN script commiteado lee STEAM_API_KEY (el import original de la biblioteca de Steam no
# está en el repo); los scripts steam-meta-*.mjs usan la API pública KEYLESS de la Store. Legado.
STEAM_API_KEY=
STEAM_ID=
