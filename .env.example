# Ocio Shit — plantilla de entorno. Copia a .env (gitignored) y rellena.
# El FRONTEND solo usará SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY (vía VITE_*, ver app).
# Lo demás (SECRET, DB_URL, credenciales) es SOLO para los scripts locales de carga/verificación
# y NUNCA entra en el bundle, el repo ni los logs (tecnico.md §3.2.sec).

# ── Supabase (Sprint A) ──────────────────────────────────────────────────────
# Las PUBLIC_* son las que usará TAMBIÉN el frontend (convención SvelteKit: PUBLIC_ = cliente).
# Project Settings → Data API (URL) / API Keys (publishable + secret).
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx          # SIN PUBLIC_ → nunca va al cliente

# Project Settings → Database → Connection string → URI (incluye la contraseña de la BD).
# Necesaria para aplicar DDL (schema/rls) y ejecutar el SQL del compilador (PostgREST no hace DDL).
# Solo local (este .env gitignored); jamás en el frontend.
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# El ÚNICO usuario del archivo (Supabase Auth) = tu login en la app. Los scripts crean/usan esta
# cuenta; su uid pasa a ser el owner_id de todas las filas (RLS). Contraseña fuerte.
OCIO_AUTH_EMAIL=tu-email@ejemplo.com
OCIO_AUTH_PASSWORD=una-contraseña-larga-y-única

# ── Enriquecimiento Fase 4 (heredado, no se usa en Sprint A) ─────────────────
STEAM_API_KEY=
STEAM_ID=
